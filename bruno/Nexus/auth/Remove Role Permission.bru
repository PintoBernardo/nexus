meta {
  name: Remove Role Permission
  type: http
  seq: 19
}

delete {
  url: http://127.0.0.1:8000/api/admin/auth/roles/:name/perms/:permission
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:path {
  name: manager
  permission: users:read
}

settings {
  encodeUrl: true
  timeout: 5000
}
