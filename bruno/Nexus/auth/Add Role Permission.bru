meta {
  name: Add Role Permission
  type: http
  seq: 18
}

post {
  url: http://127.0.0.1:8000/api/admin/auth/roles/:name/perms
  body: json
  auth: bearer
}

body:json {
  {
    "permission": "users:read"
  }
}

auth:bearer {
  token: {{token}}
}

vars:path {
  name: manager
}

settings {
  encodeUrl: true
  timeout: 5000
}
