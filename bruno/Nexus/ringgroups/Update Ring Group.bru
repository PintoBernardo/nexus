meta {
  name: Update Ring Group
  type: http
  seq: 4
}

put {
  url: http://127.0.0.1:8000/api/ringgroups/:id
  body: json
  auth: bearer
}

body:json {
  {
    "strategy": "hunt",
    "description": "Updated description"
  }
}

auth:bearer {
  token: {{token}}
}

settings {
  encodeUrl: true
  timeout: 5000
}

vars:path {
  id: 1
}
