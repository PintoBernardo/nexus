meta {
  name: Set All Members
  type: http
  seq: 8
}

put {
  url: http://127.0.0.1:8000/api/ringgroups/:id/members
  body: json
  auth: bearer
}

body:json {
  {
    "members": ["101", "102", "103"]
  }
}

auth:bearer {
  token: {{token}}
}

settings {
  encodeUrl: true
  timeout: 5000
}

vars:path {
  id: 1
}
