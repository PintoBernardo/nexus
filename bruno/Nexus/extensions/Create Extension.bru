meta {
  name: Create Extension
  type: http
  seq: 3
}

post {
  url: http://127.0.0.1:8000/api/extensions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "user_id": 1,
    "type": "sip",
    "extension": "1001",
    "secret": "secret123",
    "display_name": "John Doe",
    "context": "from-internal",
    "enabled": true
  }
}

settings {
  encodeUrl: true
  timeout: 5000
}
